# Copy this to .env and fill in your values
FIREWORKS_API_KEY=your_fireworks_api_key_here

# Model used for scenario generation + follow-up generation (Fireworks-hosted)
SCENARIO_MODEL=accounts/fireworks/models/gemma-4-31b-it

# Model used for judging / evaluation (Gemma 4 on Fireworks)
JUDGE_MODEL=accounts/fireworks/models/gemma-4-31b-it

# Max concurrent scenario executions
MAX_CONCURRENCY=30

# Max turns per simulated conversation
MAX_TURNS=3

# CORS origin for the frontend (Chetan/Hamza's frontend will run here)
FRONTEND_ORIGIN=http://localhost:3000
