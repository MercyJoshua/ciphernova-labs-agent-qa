# Copy this to .env and fill in your values
FIREWORKS_API_KEY=your_fireworks_api_key_here

# Model used for scenario generation (Fireworks-hosted)
SCENARIO_MODEL=accounts/fireworks/models/deepseek-v4-pro

# Model used for follow-up message generation during execution (Fireworks-hosted)
EXECUTION_MODEL=accounts/fireworks/models/deepseek-v4-pro

# Model used for judging / evaluation (Fireworks-hosted)
JUDGE_MODEL=accounts/fireworks/models/deepseek-v4-pro

# Max concurrent scenario executions
MAX_CONCURRENCY=30

# Max turns per simulated conversation
MAX_TURNS=3

# CORS origin (single origin) — set to your deployed frontend URL
FRONTEND_ORIGIN=http://localhost:3000

# CORS origins (JSON list) — overrides FRONTEND_ORIGIN if set
# CORS_ORIGINS=["https://your-frontend.vercel.app"]

# =============================================================================
# Gemma Consensus Judge (optional)
# =============================================================================
# Set to "true" to enable optional Gemma consensus layer.
# When disabled (default), the backend behaves exactly as before.
# ENABLE_GEMMA_CONSENSUS=false

# Separate Fireworks API key for Gemma — DO NOT reuse FIREWORKS_API_KEY
# GEMMA_FIREWORKS_API_KEY=

# Fireworks base URL for Gemma (OpenAI-compatible endpoint)
# GEMMA_BASE_URL=https://api.fireworks.ai/inference/v1

# Gemma judge model deployment
# GEMMA_MODEL=accounts/spsanjay1010-0mwbn1q/models/judge-lora#accounts/spsanjay1010-0mwbn1q/deployments/gjah7yhx

# Gemma API timeout in seconds
# GEMMA_TIMEOUT=30
